<Window x:Class="SvgShow.ComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SvgShow.Models"
        mc:Ignorable="d"
        Title="SVG比对" Height="500" Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- 文件夹图标模板 -->
        <HierarchicalDataTemplate DataType="{x:Type local:FolderItem}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Image Width="16" Height="16" Margin="2">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Geometry="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#888" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#FFD966"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
                <TextBlock Text="{Binding Name}" Margin="2,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- SVG文件图标模板 -->
        <DataTemplate DataType="{x:Type local:SvgFileItem}">
            <StackPanel Orientation="Horizontal">
                <Image Width="16" Height="16" Margin="2">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Geometry="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#888" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#4DA6FF"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
                <TextBlock Text="{Binding FileName}" Margin="2,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：比对结果区 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#E8F0FE" BorderBrush="#4DA6FF" BorderThickness="0,0,0,1" Padding="8">
                <DockPanel>
                    <TextBlock Text="比对结果（点击开始比对将在主界面新建SVG）" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtCurrentPreview" Text="(无)" Margin="20,0,0,0" 
                               VerticalAlignment="Center" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="Gray" BorderThickness="0,0,0,1">
                <TreeView x:Name="leftTreeView" BorderThickness="0"
                          MouseDoubleClick="LeftTree_MouseDoubleClick">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Background="#F5F5F5" Margin="5">
                <Button x:Name="btnStartCompare" Content="开始比对" Click="StartCompare_Click"
                        ToolTip="在主界面新建SVG文件并加载左侧第一个文件"/>
                <Button x:Name="btnExportResult" Content="导出结果" Click="ExportResult_Click" IsEnabled="False"
                        ToolTip="比对功能尚未实现"/>
                <Button Content="关闭" Click="Close_Click" Margin="20,2,2,2"/>
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

        <!-- 右侧：源文件选择区 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFF4E5" BorderBrush="#FFD966" BorderThickness="0,0,0,1" Padding="8">
                <TextBlock Text="源文件（双击移入左侧）" FontWeight="Bold" VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="Gray" BorderThickness="0,0,0,1">
                <TreeView x:Name="rightTreeView" BorderThickness="0"
                          MouseDoubleClick="RightTree_MouseDoubleClick">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <Button Grid.Row="2" Content="打开SVG" Click="OpenSvg_Click" Margin="5"
                    ToolTip="打开文件夹并把该文件夹下的所有svg添加到目录中"/>
        </Grid>
    </Grid>
</Window>
