<Window x:Class="SvgShow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="SVG可视化工具" Height="800" Width="1200"
        WindowState="Maximized">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ToolBar Grid.Row="0" Height="40">
            <Button Content="打开SVG" Click="OpenSvg_Click" ToolTip="打开一个或多个SVG文件"/>
            
            <Separator/>
            
            <Button Content="测量工具" Click="MeasureTool_Click" x:Name="btnMeasure" 
                    ToolTip="测量两点之间的距离" Background="LightGray"/>
            
            <Separator/>
            
            <Button Content="播放动画" Click="PlayAnimation_Click" x:Name="btnPlay" ToolTip="播放多SVG动画"/>
            <Button Content="暂停动画" Click="PauseAnimation_Click" x:Name="btnPause" ToolTip="暂停动画"/>
            <Button Content="停止动画" Click="StopAnimation_Click" x:Name="btnStop" ToolTip="停止动画"/>
            
            <Separator/>
            
            <Slider x:Name="sliderSpeed" Minimum="0.1" Maximum="3" Value="1" Width="100" 
                    ToolTip="动画速度" ValueChanged="SliderSpeed_ValueChanged"/>
            <TextBlock Text="速度"/>
            
            <Separator/>
            
            <Button Content="重置视图" Click="ResetView_Click" ToolTip="重置缩放和平移"/>
            
            <Separator/>
            
            <TextBlock Text="缩放:" Margin="5,0"/>
            <TextBlock x:Name="txtScale" Text="100%" Margin="5,0"/>
        </ToolBar>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <StackPanel>
                    <TextBlock Text="图层列表" FontWeight="Bold" Margin="5"/>
                    <ListBox x:Name="lstLayers" Height="Auto" Margin="2" SelectionMode="Extended">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsVisible}" Content="{Binding Name}" 
                                              Checked="LayerChecked" Unchecked="LayerChecked"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Separator Margin="5"/>
                    
                    <TextBlock Text="SVG文件" FontWeight="Bold" Margin="5"/>
                    <ListBox x:Name="lstSvgFiles" Height="Auto" Margin="2">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsActive}" Content="{Binding FileName}" 
                                              Checked="SvgFileChecked" Unchecked="SvgFileChecked"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <wv2:WebView2 x:Name="webView" Source="about:blank"/>
            </Border>
            
            <Border Grid.Column="2" Background="#F5F5F5" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <StackPanel>
                    <TextBlock Text="选中图形属性" FontWeight="Bold" Margin="5"/>
                    
                    <GroupBox Header="几何数据" Margin="5">
                        <StackPanel>
                            <TextBlock Text="类型:" Margin="2"/>
                            <TextBox x:Name="txtShapeType" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="边界:" Margin="2"/>
                            <TextBox x:Name="txtBounds" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="中心点:" Margin="2"/>
                            <TextBox x:Name="txtCenter" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="宽度:" Margin="2"/>
                            <TextBox x:Name="txtWidth" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="高度:" Margin="2"/>
                            <TextBox x:Name="txtHeight" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="坐标信息" Margin="5">
                        <StackPanel>
                            <TextBlock Text="鼠标位置:" Margin="2"/>
                            <TextBox x:Name="txtMousePosition" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="SVG坐标:" Margin="2"/>
                            <TextBox x:Name="txtSvgPosition" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="测量结果" Margin="5">
                        <StackPanel>
                            <TextBlock Text="距离:" Margin="2"/>
                            <TextBox x:Name="txtDistance" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="起点:" Margin="2"/>
                            <TextBox x:Name="txtStartPoint" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="终点:" Margin="2"/>
                            <TextBox x:Name="txtEndPoint" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>