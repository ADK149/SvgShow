<Window x:Class="SvgShow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:SvgShow.Models"
        mc:Ignorable="d"
        Title="SVG可视化工具" Height="800" Width="1200"
        WindowState="Maximized">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        
        <HierarchicalDataTemplate DataType="{x:Type local:FolderItem}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Image Width="16" Height="16" Margin="2">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Geometry="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#888" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#FFD966"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
                <TextBlock Text="{Binding Name}" Margin="2,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>
        
        <DataTemplate DataType="{x:Type local:SvgFileItem}">
            <StackPanel Orientation="Horizontal">
                <Image Width="16" Height="16" Margin="2">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Geometry="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#888" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#4DA6FF"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
                <TextBlock Text="{Binding FileName}" Margin="2,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ToolBar Grid.Row="0" Height="40">
            <Button Content="新建" Click="NewSvg_Click" ToolTip="创建新的空白SVG文件"/>
            <Button Content="打开" Click="OpenSvg_Click" ToolTip="打开SVG文件或目录"/>
            <Button Content="保存" Click="SaveSvg_Click" ToolTip="保存当前视图到打开的SVG文件"/>
            <Button Content="另存为" Click="SaveAsSvg_Click" ToolTip="将当前视图另存为SVG文件"/>
            <Button Content="导入TXT" Click="ImportTxt_Click" ToolTip="导入TXT数据到当前SVG"/>
            <Button Content="导入JSON" Click="ImportJson_Click" ToolTip="导入JSON数据到当前SVG"/>
                      
            <Separator/>

            <Button Content="重置视图" Click="ResetView_Click" ToolTip="重置缩放和平移"/>
            <TextBlock Text="缩放:" Margin="5,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtScale" Text="100%" Margin="5,0" VerticalAlignment="Center"/>
            
            <Separator/>
            
            <Button Content="关联SVG" Click="AssociateSvg_Click" x:Name="btnAssociate"
                    ToolTip="将本程序设置为.svg文件的默认打开方式"/>
            <Button Content="比对" Click="Compare_Click"
                    ToolTip="打开比对窗口，对比两个SVG文件的差异"/>
        </ToolBar>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="SVG文件目录" FontWeight="Bold" Margin="5"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  x:Name="treeScrollViewer">
                        <TreeView x:Name="treeView" Margin="2"
                                  SelectedItemChanged="TreeView_SelectedItemChanged"
                                  PreviewMouseWheel="TreeView_PreviewMouseWheel">
                            <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Gray"/>
                                            <Setter Property="Foreground" Value="#333"/>
                                            <Setter Property="BorderBrush" Value="Gray"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#333"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="FontWeight" Value="Normal"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <Border Grid.Column="1" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <wv2:WebView2 x:Name="webView" Source="about:blank"/>
            </Border>
            
            <Border Grid.Column="2" Background="#F5F5F5" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <StackPanel>
                    <TextBlock Text="选中图形属性" FontWeight="Bold" Margin="5"/>
                    
                    <GroupBox Header="当前文件" Margin="5">
                        <StackPanel>
                            <TextBlock Text="文件名:" Margin="2"/>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBox x:Name="txtCurrentFile" IsReadOnly="False" Width="160" VerticalContentAlignment="Center"/>
                                <Button Content="重命名" Click="RenameFile_Click" Margin="5,0,0,0" Padding="5,2"/>
                            </StackPanel>
                            <TextBlock Text="路径:" Margin="2"/>
                            <TextBox x:Name="txtFilePath" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="SVG样式配置" Margin="5">
                        <StackPanel>
                            <TextBlock Text="线宽:" Margin="2"/>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Slider x:Name="sliderStrokeWidth" Minimum="0.1" Maximum="5" Value="0.5" TickFrequency="0.1" Width="120"
                    ValueChanged="StrokeWidth_ValueChanged" AutoToolTipPlacement="TopLeft"/>
                                <TextBox x:Name="txtStrokeWidth" Text="0.5" Width="40" Margin="5,0" TextChanged="TxtStrokeWidth_TextChanged"/>
                            </StackPanel>
                            <TextBlock Text="文字缩放倍率:" Margin="2"/>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Slider x:Name="sliderFontSize" Minimum="0.5" Maximum="2" Value="1" TickFrequency="0.1" Width="120"
                    ValueChanged="FontSize_ValueChanged" AutoToolTipPlacement="TopLeft"/>
                                <TextBox x:Name="txtFontSize" Text="1.0" Width="40" Margin="5,0" TextChanged="TxtFontSize_TextChanged"/>
                            </StackPanel>
                            <CheckBox x:Name="chkEnableOverride" Content="启用样式覆盖" IsChecked="True" Margin="2"
                  Checked="Override_CheckedChanged" Unchecked="Override_CheckedChanged"/>
                            <Button Content="应用到当前" Click="ApplyStyle_Click" Margin="2" Padding="3"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="几何数据" Margin="5">
                        <StackPanel>
                            <TextBlock Text="类型:" Margin="2"/>
                            <TextBox x:Name="txtShapeType" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="边界:" Margin="2"/>
                            <TextBox x:Name="txtBounds" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="中心点:" Margin="2"/>
                            <TextBox x:Name="txtCenter" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="宽度:" Margin="2"/>
                            <TextBox x:Name="txtWidth" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="高度:" Margin="2"/>
                            <TextBox x:Name="txtHeight" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                                                            
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>