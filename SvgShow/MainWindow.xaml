<Window x:Class="SvgShow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:SvgShow.Models"
        mc:Ignorable="d"
        Title="SVG可视化工具" Height="800" Width="1200"
        WindowState="Maximized">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        
        <HierarchicalDataTemplate DataType="{x:Type local:FolderItem}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Image Width="16" Height="16" Margin="2">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Geometry="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#888" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#FFD966"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
                <TextBlock Text="{Binding Name}" Margin="2,0"/>
            </StackPanel>
        </HierarchicalDataTemplate>
        
        <DataTemplate DataType="{x:Type local:SvgFileItem}">
            <StackPanel Orientation="Horizontal">
                <Image Width="16" Height="16" Margin="2">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <GeometryDrawing Geometry="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z">
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="#888" Thickness="1"/>
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#4DA6FF"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
                <TextBlock Text="{Binding FileName}" Margin="2,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ToolBar Grid.Row="0" Height="40">
            <Button Content="打开SVG" Click="OpenSvg_Click" ToolTip="打开SVG文件或目录"/>
            
            <Separator/>
            
            <Button Content="测量工具" Click="MeasureTool_Click" x:Name="btnMeasure" 
                    ToolTip="测量两点之间的距离" Background="LightGray"/>
            
            <Separator/>
            
            <Button Content="播放动画" Click="PlayAnimation_Click" x:Name="btnPlay" ToolTip="播放多SVG动画"/>
            <Button Content="暂停动画" Click="PauseAnimation_Click" x:Name="btnPause" ToolTip="暂停动画"/>
            <Button Content="停止动画" Click="StopAnimation_Click" x:Name="btnStop" ToolTip="停止动画"/>
            
            <Separator/>
            
            <Slider x:Name="sliderSpeed" Minimum="0.1" Maximum="3" Value="1" Width="100" 
                    ToolTip="动画速度" ValueChanged="SliderSpeed_ValueChanged"/>
            <TextBlock Text="速度"/>
            
            <Separator/>
            
            <Button Content="重置视图" Click="ResetView_Click" ToolTip="重置缩放和平移"/>
            
            <Separator/>
            
            <TextBlock Text="缩放:" Margin="5,0"/>
            <TextBlock x:Name="txtScale" Text="100%" Margin="5,0"/>
            
            <Separator/>
            
            <Button Content="关联SVG" Click="AssociateSvg_Click" x:Name="btnAssociate"
                    ToolTip="将本程序设置为.svg文件的默认打开方式"/>
        </ToolBar>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="SVG文件目录" FontWeight="Bold" Margin="5"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  x:Name="treeScrollViewer">
                        <TreeView x:Name="treeView" Margin="2"
                                  SelectedItemChanged="TreeView_SelectedItemChanged"
                                  PreviewMouseWheel="TreeView_PreviewMouseWheel">
                            <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Gray"/>
                                            <Setter Property="Foreground" Value="#333"/>
                                            <Setter Property="BorderBrush" Value="Gray"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#333"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="FontWeight" Value="Normal"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <Border Grid.Column="1" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <wv2:WebView2 x:Name="webView" Source="about:blank"/>
            </Border>
            
            <Border Grid.Column="2" Background="#F5F5F5" BorderBrush="Gray" BorderThickness="1" Margin="2">
                <StackPanel>
                    <TextBlock Text="选中图形属性" FontWeight="Bold" Margin="5"/>
                    
                    <GroupBox Header="几何数据" Margin="5">
                        <StackPanel>
                            <TextBlock Text="类型:" Margin="2"/>
                            <TextBox x:Name="txtShapeType" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="边界:" Margin="2"/>
                            <TextBox x:Name="txtBounds" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="中心点:" Margin="2"/>
                            <TextBox x:Name="txtCenter" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="宽度:" Margin="2"/>
                            <TextBox x:Name="txtWidth" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="高度:" Margin="2"/>
                            <TextBox x:Name="txtHeight" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="坐标信息" Margin="5">
                        <StackPanel>
                            <TextBlock Text="鼠标位置:" Margin="2"/>
                            <TextBox x:Name="txtMousePosition" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="SVG坐标:" Margin="2"/>
                            <TextBox x:Name="txtSvgPosition" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="测量结果" Margin="5">
                        <StackPanel>
                            <TextBlock Text="距离:" Margin="2"/>
                            <TextBox x:Name="txtDistance" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="起点:" Margin="2"/>
                            <TextBox x:Name="txtStartPoint" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="终点:" Margin="2"/>
                            <TextBox x:Name="txtEndPoint" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="当前文件" Margin="5">
                        <StackPanel>
                            <TextBlock Text="文件名:" Margin="2"/>
                            <TextBox x:Name="txtCurrentFile" IsReadOnly="True" Margin="2"/>
                            <TextBlock Text="路径:" Margin="2"/>
                            <TextBox x:Name="txtFilePath" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>